APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_PATH=./data/paper_agent.sqlite3
STORAGE_ROOT=./data/storage

# DeepSeek is OpenAI-compatible for chat completions.
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace-with-your-key
LLM_MODEL=deepseek-chat
LLM_INTERFACE=chat_completions
LLM_MAX_CONTEXT_CHARS=14000

BRAVE_API_KEY=

# Put your PaddleOCR token here. Do not commit a real token.
PADDLEOCR_TOKEN=
PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_MODEL=PaddleOCR-VL-1.5
PADDLEOCR_DAILY_PAGE_LIMIT=20000
PADDLEOCR_CHUNK_PAGES=10

DEFAULT_ARXIV_CATEGORIES=cs.AI,cs.CL,cs.CV,cs.GR,cs.LG,stat.ML
CRAWL_INTERVAL_MINUTES=720
